# Copy these names into Vercel: Project → Settings → Environment Variables
# (Production and Preview as needed). See SETUP.md.

MONGODB_URI=
MONGODB_DB_NAME=emailsignature

BETTER_AUTH_SECRET=
# Your Vercel deployment URL or custom domain (no trailing slash)
BETTER_AUTH_URL=https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Optional: wire sendResetPassword in lib/auth/server.ts
# RESEND_API_KEY=
