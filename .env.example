# Copy into Vercel: Project → Settings → Environment Variables. See SETUP.md.

MONGODB_URI=
MONGODB_DB_NAME=emailsignature

BETTER_AUTH_SECRET=
# Your Vercel deployment URL or custom domain (no trailing slash)
BETTER_AUTH_URL=https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Optional: same as public app URL if you use relative /images/... in signatures and need absolute URLs in copied HTML
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Optional: wire sendResetPassword in lib/auth/server.ts
# RESEND_API_KEY=

# Vercel Blob — organization logo uploads (POST /api/dashboard/organization/logo)
BLOB_READ_WRITE_TOKEN=

# Gmail “Apply signature” (OAuth + Gmail API). Callback URL must match Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional; defaults to {BETTER_AUTH_URL or NEXT_PUBLIC_APP_URL}/api/integrations/gmail/callback
# GOOGLE_REDIRECT_URI=https://your-project.vercel.app/api/integrations/gmail/callback
# Optional; recommended in production — 32+ byte secret for AES-256-GCM token encryption at rest
# GOOGLE_OAUTH_ENCRYPTION_KEY=
